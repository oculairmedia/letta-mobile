        log_err "Server is not responding"
        return 1
    fi
}

# ============== TEST SYNC ==============
cmd_test_sync() {
    local agent_id="$1"; shift
    local conversation=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --conversation) conversation="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    log_info "=== SYNC TEST for agent: $agent_id ==="
    echo ""

    # Step 1: Initial fetch (like app does on first load)
    log_info "Step 1: Initial fetch (order=desc, limit=10, simulating app startup)"
    local initial_url="/v1/agents/$agent_id/messages?limit=10&order=desc"
    [[ -n "$conversation" ]] && initial_url+="&conversation_id=$conversation"
    
    local initial_response=$(api_get "$initial_url")
    local initial_count=$(echo "$initial_response" | jq 'length')
    log_ok "Fetched $initial_count messages"
    
    # Get the newest message ID (will be first after .reversed() in app)
    # But lastSyncedMessageId is set to .lastOrNull() AFTER reverse, which is the newest
    local newest_id=$(echo "$initial_response" | jq -r '.[0].id')
    local oldest_id=$(echo "$initial_response" | jq -r '.[-1].id')
    
    echo "  Newest (DESC[0]):  $newest_id"
    echo "  Oldest (DESC[-1]): $oldest_id"
    echo ""
    
    # After .reversed(), the list becomes [oldest...newest]
    # .lastOrNull() returns newest_id ✓
    log_info "App sets lastSyncedMessageId = newest_id (correct)"
    echo ""

    # Step 2: Simulate checkForNewMessages
    log_info "Step 2: Check for new messages (after=$newest_id, order=asc)"
    local check_url="/v1/agents/$agent_id/messages?limit=50&order=asc&after=$newest_id"
    [[ -n "$conversation" ]] && check_url+="&conversation_id=$conversation"
    
    local new_response=$(api_get "$check_url")
    local new_count=$(echo "$new_response" | jq 'length')
    
    if [[ "$new_count" -gt 0 ]]; then
        log_ok "Found $new_count NEW messages!"
        echo "$new_response" | jq $JQ_OPTS '.[] | "  \(.date[:19]) | \(.message_type[:20])"'
    else
        log_warn "No new messages found (this is expected if no activity since fetch)"
    fi
    echo ""

    # Step 3: Test older messages fetch
    log_info "Step 3: Fetch older messages (before=$oldest_id, order=desc)"
    local older_url="/v1/agents/$agent_id/messages?limit=10&order=desc&before=$oldest_id"
    [[ -n "$conversation" ]] && older_url+="&conversation_id=$conversation"
    
    local older_response=$(api_get "$older_url")
    local older_count=$(echo "$older_response" | jq 'length')
    log_ok "Fetched $older_count older messages"
    echo ""

    log_info "=== SYNC TEST COMPLETE ==="
}

# ============== SYNC DRIFT ==============
# Programmatic regression detector for "chat screen not updating" bugs
# like letta-mobile-nw2e. Instead of eyeballing the phone, we read the
# client's persisted "processed" cursor from the device via `adb run-as`,
# query the server for messages newer than that cursor, and report:
#
#   - Wall-clock drift (server-latest - client-processed) in seconds
#   - Number of messages the background heartbeat worker has NOT processed yet
#   - A verdict: HEALTHY (< 30s, < 5 unprocessed), STALE (30-120s or moderate lag),
#     BROKEN (> 120s or >= 10 unprocessed)
#
# Bonus: --watch runs it every N seconds and reports whether drift is
# growing (sync loop stuck), shrinking (catching up), or flat.
#
# Prereq: adb must be connected to the device (`adb devices`), and the
# debug build of com.letta.mobile is installed (run-as works only on
# debuggable apks).
cmd_sync_drift() {
    local agent_id=""
    local conversation=""
    local watch=false
    local interval=5
    local iterations=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent_id="$2"; shift 2 ;;
            --conversation) conversation="$2"; shift 2 ;;
            --watch) watch=true; shift ;;
            --interval) interval="$2"; shift 2 ;;
            --iterations) iterations="$2"; shift 2 ;;
            -h|--help)
                cat <<EOF
sync-drift - Measure client/server sync drift via adb + server query.

USAGE:
    letta-cli sync-drift --agent <agent_id> --conversation <conv_id> [--watch] [--interval SEC] [--iterations N]

OPTIONS:
    --agent AGENT_ID          Required. Agent owning the conversation.
    --conversation CONV_ID    Required. Conversation to measure drift on.
    --watch                   Poll continuously.
    --interval SECONDS        Poll interval when --watch (default: 5).
    --iterations N            Stop after N polls (default: 0 = forever).

EXAMPLES:
    # One-shot drift check
    letta-cli sync-drift --agent agent-xxx --conversation conv-yyy

    # Watch drift for 60s (12 polls at 5s interval) to see if it grows
    letta-cli sync-drift --agent agent-xxx --conversation conv-yyy --watch --iterations 12
EOF
                return 0
                ;;
            *) shift ;;
        esac
    done

    if [[ -z "$agent_id" || -z "$conversation" ]]; then
        log_err "sync-drift requires --agent and --conversation"
        return 1
    fi

    if ! command -v adb >/dev/null 2>&1; then
        log_err "adb not on PATH; sync-drift needs adb to read client state"
        return 1
    fi

    _sync_drift_once() {
        # --- Read client cursor from device ---
        local client_processed
        client_processed=$(adb shell "run-as com.letta.mobile cat /data/user/0/com.letta.mobile/shared_prefs/channel_sync_state.xml 2>/dev/null" 2>/dev/null \
            | grep "processed::$conversation" \
            | sed -E 's/.*>([^<]+)<.*/\1/' \
            | head -1 \
            | tr -d '\r\n')
        if [[ -z "$client_processed" ]]; then
            echo "CLIENT_CURSOR=MISSING (conversation never processed by client)"
            client_processed="1970-01-01T00:00:00Z"
        fi

        # --- Query server for latest message timestamp ---
        local server_resp
        server_resp=$(api_get "/v1/agents/$agent_id/messages?limit=50&order=desc&conversation_id=$conversation" 2>/dev/null)
        local server_latest
        server_latest=$(echo "$server_resp" | jq -r 'map(.date // empty) | map(select(length > 0)) | sort | last // empty' 2>/dev/null)
        if [[ -z "$server_latest" ]]; then
            echo "SERVER_LATEST=MISSING (empty response or bad auth)"
            return 2
        fi

        # --- Count unprocessed messages (server entries newer than cursor) ---
        local unprocessed
        unprocessed=$(echo "$server_resp" | jq -r --arg cursor "$client_processed" '[.[] | select(.date > $cursor)] | length' 2>/dev/null)
        [[ -z "$unprocessed" ]] && unprocessed=0

        # --- Compute drift in seconds ---
        local drift_sec
        drift_sec=$(python3 -c "
from datetime import datetime, timezone
def parse(s):
    s = s.rstrip('Z').split('.')[0]
    return datetime.fromisoformat(s).replace(tzinfo=timezone.utc)
try:
    c = parse('$client_processed')
    s = parse('$server_latest')
    print(int((s - c).total_seconds()))
except Exception as e:
    print('ERR')
" 2>/dev/null)

        # --- Verdict ---
        local verdict color
        if [[ "$drift_sec" == "ERR" ]]; then
            verdict="UNKNOWN"; color="$YELLOW"
        elif [[ "$drift_sec" -lt 30 && "$unprocessed" -lt 5 ]]; then
            verdict="HEALTHY"; color="$GREEN"
        elif [[ "$drift_sec" -lt 120 && "$unprocessed" -lt 10 ]]; then
            verdict="STALE"; color="$YELLOW"
        else
            verdict="BROKEN"; color="$RED"
        fi

        local ts
        ts=$(date +%H:%M:%S)
        echo -e "[$ts] client=$client_processed  server=$server_latest  drift=${drift_sec}s  unprocessed=$unprocessed  ${color}${verdict}${NC}"

        # Return non-zero on BROKEN so --watch loops can honor exit codes downstream
        [[ "$verdict" == "BROKEN" ]] && return 1
        return 0
    }

    log_info "=== SYNC DRIFT for agent=$agent_id conv=$conversation ==="
    echo ""

    if [[ "$watch" == "true" ]]; then
        local count=0
        local prev_drift=""
        while :; do
            local output
            output=$(_sync_drift_once)
            echo "$output"
            # Trend analysis — extract drift value, compare to previous
            local this_drift
            this_drift=$(echo "$output" | grep -oE "drift=[0-9]+s" | grep -oE "[0-9]+")
            if [[ -n "$prev_drift" && -n "$this_drift" ]]; then
                if [[ "$this_drift" -gt "$prev_drift" ]]; then
                    echo "    trend: ⬆ drift growing by $((this_drift - prev_drift))s"
                elif [[ "$this_drift" -lt "$prev_drift" ]]; then
                    echo "    trend: ⬇ drift shrinking by $((prev_drift - this_drift))s"
                else
                    echo "    trend: → flat"
                fi
            fi
            prev_drift="$this_drift"
            count=$((count + 1))
            if [[ "$iterations" -gt 0 && "$count" -ge "$iterations" ]]; then
                break
            fi
            sleep "$interval"
        done
    else
        _sync_drift_once
    fi
}

# ============== STREAM WATCH ==============
# Resume-stream pattern validator for letta-mobile-qkg9 replacement plan.
#
# Self-hosted Letta servers expose POST /v1/conversations/{id}/stream, which
# "resumes the stream of the most recent active run." If no run is active,
# returns 404 with "No active runs found for this conversation." If one IS
# active, returns an SSE stream multiplexing events from that run to every
# subscribed client — including clients that didn't initiate the run.
#
# This subcommand uses that endpoint as a long-lived, bandwidth-efficient
# subscription. Loop:
#   1. POST /stream.
#   2. If 200 with event-stream: print events until close.
#   3. If 404 "no active run": sleep backoff, retry.
#   4. Backoff is exponential from --backoff-start to --backoff-max.
#   5. Backoff resets to start on every successful connect.
#
# This is the pattern TimelineSyncLoop will use to get realtime incoming-
# message delivery without polling.
cmd_stream_watch() {
    local conversation=""
    local backoff_start=2
    local backoff_max=30
    local json_out=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --conversation) conversation="$2"; shift 2 ;;
            --backoff-start) backoff_start="$2"; shift 2 ;;
            --backoff-max) backoff_max="$2"; shift 2 ;;
            --json) json_out=true; shift ;;
            -h|--help)
                cat <<EOF
stream-watch — subscribe to live SSE events for a conversation using the
resume-stream pattern. Exits only on Ctrl-C.

USAGE:
    letta-cli stream-watch --conversation CONV_ID [--backoff-start SEC] [--backoff-max SEC] [--json]

OPTIONS:
    --conversation CONV_ID   Required.
    --backoff-start SEC      Initial backoff when no active run (default: 2).
    --backoff-max SEC        Cap on exponential backoff (default: 30).
    --json                   Emit raw JSON lines instead of formatted output.

SEMANTICS:
    - HTTP 200 + event-stream: we are subscribed. Events print live.
    - HTTP 404 "No active runs found": sleep backoff, retry. Doubles each
      consecutive 404 up to backoff_max.
    - Any other error: print and retry at backoff_max interval.
    - Successful connect resets backoff to start.

EXAMPLES:
    letta-cli stream-watch --conversation conv-1598043a-d864-4a5c-a59d-8622f0b4eb5d
    letta-cli stream-watch --conversation conv-xxx --backoff-start 5 --backoff-max 60
EOF
                return 0
                ;;
            *) shift ;;
        esac
    done

    if [[ -z "$conversation" ]]; then
        log_err "stream-watch requires --conversation"
        return 1
    fi

    local url="${BASE_URL}/v1/conversations/${conversation}/stream"
    local headers=(-H "Content-Type: application/json" -H "Accept: text/event-stream")
    if [[ -n "$LETTA_TOKEN" ]]; then
        headers+=(-H "Authorization: Bearer $LETTA_TOKEN")
    fi

    local backoff="$backoff_start"
    local connects=0
    local idle_polls=0
    local events_received=0
    local start_ts
    start_ts=$(date +%s)

    [[ "$json_out" != "true" ]] && log_info "=== STREAM-WATCH conv=$conversation start=$(date +%H:%M:%S) ==="

    # Trap to print a summary on exit.
    trap '_stream_watch_summary' EXIT

    _stream_watch_summary() {
        local now
        now=$(date +%s)
        local dur=$((now - start_ts))
        [[ "$json_out" != "true" ]] && {
            echo ""
            log_info "=== STREAM-WATCH SUMMARY ==="
            echo "  Duration:        ${dur}s"
            echo "  Successful connects: $connects"
            echo "  Idle 404 polls:  $idle_polls"
            echo "  Events received: $events_received"
        }
    }

    while :; do
        # Attempt connect. -D - writes headers to stdout, we parse status then content.
        local tmp
        tmp=$(mktemp)
        local status
        # Use --no-buffer so SSE frames flush as they arrive.
        # -D /dev/stderr lets us see HTTP status before body.
        # We POST with empty JSON body.
        status=$(curl -sN --no-buffer -X POST "$url" "${headers[@]}" \
            -w "HTTP_STATUS:%{http_code}\n" \
            -d '{}' 2>/dev/null | {
                # Read line-by-line; detect status line we appended via -w at EOF.
                # -w trailer only fires when request completes (not during stream),
                # so we rely on first-line shape to distinguish 200 vs 4xx.
                local first_line_read=false
                local found_status="unknown"
                while IFS= read -r line; do
                    if [[ "$line" =~ ^HTTP_STATUS:([0-9]+)$ ]]; then
                        found_status="${BASH_REMATCH[1]}"
                        continue
                    fi
                    if [[ "$first_line_read" == "false" ]]; then
                        first_line_read=true
                        # JSON error body signals 4xx/5xx.
                        if [[ "$line" == "{\"detail\":"* ]]; then
                            # 404/409 JSON response. Capture message.
                            echo "__STATUS__:4xx"
                            echo "__DETAIL__:$line"
                            continue
                        fi
                    fi
                    # SSE frame or continuation.
                    if [[ -n "$line" ]]; then
                        echo "__EVENT__:$line"
                    fi
                done
                echo "__FINAL_STATUS__:$found_status"
            } > "$tmp")

        # Parse the collected output.
        local had_events=false
        local had_error=false
        local error_detail=""
        while IFS= read -r line; do
            case "$line" in
                __STATUS__:4xx)
                    had_error=true
                    ;;
                __DETAIL__:*)
                    error_detail="${line#__DETAIL__:}"
                    ;;
                __EVENT__:*)
                    had_events=true
                    local evt="${line#__EVENT__:}"
                    events_received=$((events_received + 1))
                    if [[ "$json_out" == "true" ]]; then
                        echo "$evt"
                    else
                        local ts
                        ts=$(date +%H:%M:%S.%3N)
                        # Pretty-print data: lines with type extraction.
                        if [[ "$evt" =~ ^data:\ (.*)$ ]]; then
                            local payload="${BASH_REMATCH[1]}"
                            local mtype
                            mtype=$(echo "$payload" | jq -r '.message_type // empty' 2>/dev/null)
                            if [[ -n "$mtype" ]]; then
                                echo "[$ts] event  type=$mtype  $(echo "$payload" | jq -r '{run_id,id,seq_id}|to_entries|map("\(.key)=\(.value)")|join(" ")' 2>/dev/null)"
                            else
                                echo "[$ts] data   $payload" | head -c 200; echo
                            fi
                        else
                            echo "[$ts] $evt"
                        fi
                    fi
                    ;;
                __FINAL_STATUS__:*) ;;
            esac
        done < "$tmp"
        rm -f "$tmp"

        if [[ "$had_events" == "true" ]]; then
            connects=$((connects + 1))
            backoff="$backoff_start"
            [[ "$json_out" != "true" ]] && echo "[$(date +%H:%M:%S)] stream closed cleanly (run finished). reset backoff=${backoff}s"
        elif [[ "$had_error" == "true" ]]; then
            idle_polls=$((idle_polls + 1))
            if [[ "$json_out" != "true" ]]; then
                # Classify common detail strings.
                if [[ "$error_detail" == *"No active runs"* ]]; then
                    echo "[$(date +%H:%M:%S)] idle — no active run. sleep=${backoff}s"
                else
                    echo "[$(date +%H:%M:%S)] other error: $error_detail. sleep=${backoff}s"
                fi
            fi
        else
            idle_polls=$((idle_polls + 1))
            [[ "$json_out" != "true" ]] && echo "[$(date +%H:%M:%S)] no data received (connection error?). sleep=${backoff}s"
        fi

        sleep "$backoff"
        # Exponential backoff with cap.
        backoff=$((backoff * 2))
        [[ "$backoff" -gt "$backoff_max" ]] && backoff="$backoff_max"
    done
}

# ============== CLASSIFY APPROVALS ==============
# First-line diagnostic for "the chat UI is mislabeling tool results" bugs
# (letta-mobile-3nqa). USE THIS BEFORE SPECULATING FROM SOURCE.
#
# Original purpose (letta-mobile-o9ce): regression detector that catches
# bypassPermissions auto-approval echoes which the pre-fix Android client
# rendered as "Rejected" cards (ChatMessageComponents.kt:328 treated
# approve=null as approved=false).
#
# Reports:
#   - tool_return_message.status                  (success / error / other)
#   - approval_response_message.approve           (true / false / null / missing)
#   - approval_response_message.approvals[].approve (same buckets)
#   - Android-mapper classification:
#       * "auto-approved (suppressed)" -> approve=null, all approvals[].approve=null  ⚠ bypass fingerprint
#       * "explicit approved"          -> any decision == true
#       * "explicit rejected"          -> all explicit decisions == false
#
# WARNs explicitly when ANY response has all-null decisions (the
# bypassPermissions fingerprint). The Android UI must NOT render those as
# Rejected — see ChatMessageComponents.kt:326-355 (explicitDecisions guard).
#
# Flags:
#   --json    Emit a single machine-readable JSON object (no human prose).
#
# Exit code: non-zero if any auto-approval echo is detected (so CI / smoke
# tests can fail the build if a regression slips back in).
cmd_classify_approvals() {
    local conv_id=""
    local as_json=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) as_json=1; shift ;;
            -h|--help)
                cat <<EOF
letta-cli classify-approvals <conversation_id> [--json]

First-line UI-mislabel diagnostic. Buckets approval/tool_return messages
and warns on the bypassPermissions fingerprint that previously caused
every auto-approved Bash call to render as Rejected.
EOF
                return 0
                ;;
            *) conv_id="$1"; shift ;;
        esac
    done
    if [[ -z "$conv_id" ]]; then
        log_err "Usage: letta-cli classify-approvals <conversation_id> [--json]"
        return 1
    fi

    local payload
    payload=$(api_get "/v1/conversations/$conv_id/messages?limit=1000")

    # ---- Compute the full report once via jq, JSON-shaped. ----
    local report
    report=$(echo "$payload" | jq --arg conv "$conv_id" '
      def bucket_top(m): if m | has("approve") | not then "missing"
                        elif m.approve == null then "null"
                        elif m.approve == true then "true"
                        elif m.approve == false then "false"
                        else (m.approve | tostring) end;
      def bucket_nested(a): if a | has("approve") | not then "missing"
                            elif a.approve == null then "null"
                            elif a.approve == true then "true"
                            elif a.approve == false then "false"
                            else (a.approve | tostring) end;

      [.[] | select(.message_type == "approval_response_message")] as $resps
      | [.[] | select(.message_type == "tool_return_message")] as $rets
      | {
          conversation: $conv,
          total_messages: length,
          tool_return_status: (
            $rets
            | group_by(.status // "missing")
            | map({key: (.[0].status // "missing"), value: length})
            | from_entries
          ),
          top_level_approve: (
            $resps
            | map(bucket_top(.))
            | group_by(.) | map({key: .[0], value: length}) | from_entries
          ),
          nested_approve: (
            [$resps[] | (.approvals // [])[] | bucket_nested(.)]
            | group_by(.) | map({key: .[0], value: length}) | from_entries
          ),
          all_null_decision_responses: (
            $resps
            | map(select(
                (.approve == null) and
                ((.approvals // []) | all(.approve == null))
              ))
            | length
          ),
          android_mapper_classification: {
            auto_approved_suppressed: (
              $resps
              | map(select(
                  (.approve == null) and
                  ((.approvals // []) | all(.approve == null))
                ))
              | length
            ),
            explicit_approved: (
              $resps
              | map(select(
                  (.approve == true) or
                  ((.approvals // []) | any(.approve == true))
                ))
              | length
            ),
            explicit_rejected: (
              $resps
              | map(select(
                  ((.approve == false) or
                   ((.approvals // []) | any(.approve == false))) and
                  ((.approve == true) | not) and
                  ((.approvals // []) | any(.approve == true) | not)
                ))
              | length
            ),
          },
        }
        | .bypass_permissions_fingerprint = (.all_null_decision_responses > 0)
    ')

    if [[ "$as_json" -eq 1 ]]; then
        echo "$report" | jq -c .
        local mis
        mis=$(echo "$report" | jq '.all_null_decision_responses')
        [[ "${mis:-0}" -gt 0 ]] && return 2 || return 0
    fi

    # ---- Human report ----
    log_info "Pulling messages for $conv_id"
    local total
    total=$(echo "$report" | jq '.total_messages')
    log_ok "Loaded $total messages"

    echo ""
    log_info "tool_return_message.status:"
    echo "$report" | jq -r '.tool_return_status | if length == 0 then "  (none)" else (to_entries[] | "  \(.key): \(.value)") end'

    echo ""
    log_info "approval_response_message.approve (top-level):"
    echo "$report" | jq -r '.top_level_approve | if length == 0 then "  (none)" else (to_entries[] | "  \(.key): \(.value)") end'

    echo ""
    log_info "approval_response_message.approvals[].approve (nested):"
    echo "$report" | jq -r '.nested_approve | if length == 0 then "  (none)" else (to_entries[] | "  \(.key): \(.value)") end'

    echo ""
    log_info "Android mapper classification:"
    echo "$report" | jq -r '.android_mapper_classification | to_entries[] | "  \(.key): \(.value)"'

    echo ""
    log_info "First 3 approval_response_message samples (raw):"
    echo "$payload" | jq -r '
      [.[] | select(.message_type == "approval_response_message")] | .[0:3]
      | .[] | {
          id, approve, reason,
          approvals: ((.approvals // []) | map({type, tool_call_id, approve, status, reason}))
        }'

    echo ""
    local mislabeled
    mislabeled=$(echo "$report" | jq '.all_null_decision_responses')
    if [[ "${mislabeled:-0}" -gt 0 ]]; then
        log_warn "$mislabeled approval_response_message(s) have NO explicit decision."
        log_warn "  This is the bypassPermissions fingerprint. The Android UI must NOT"
        log_warn "  render these as 'Rejected' (see ChatMessageComponents.kt:326-355)."
        log_warn "  If you see Rejected cards in the app for this conversation, the fix did not ship."
        return 2
    else
        log_ok "Every approval_response_message has at least one explicit approve=true|false."
    fi
}

# ---- Self-test for cmd_classify_approvals (jq-only, no live server). ----
# Run with: letta-cli classify-approvals --self-test
# Covers the three buckets called out in letta-mobile-3nqa acceptance criteria.
_classify_approvals_self_test() {
    local fail=0
    local fixture_null='[
      {"message_type":"approval_response_message","approve":null,"approvals":[{"type":"tool","status":"success"}]},
      {"message_type":"approval_response_message","approve":null,"approvals":[{"type":"tool","status":"success"}]},
      {"message_type":"tool_return_message","status":"success"}
    ]'
    local fixture_true='[
      {"message_type":"approval_response_message","approve":true,"approvals":[{"type":"tool","approve":true,"status":"success"}]},
      {"message_type":"tool_return_message","status":"success"}
    ]'
    local fixture_false='[
      {"message_type":"approval_response_message","approve":false,"approvals":[{"type":"tool","approve":false,"status":"error"}]},
      {"message_type":"tool_return_message","status":"error"}
    ]'

    _check_classify() {
        local fixture="$1" expect_null="$2" expect_fingerprint="$3" label="$4"
        local got
        got=$(echo "$fixture" | jq '
          [.[] | select(.message_type == "approval_response_message")
                | select((.approve == null) and ((.approvals // []) | all(.approve == null)))
          ] | length
        ')
        if [[ "$got" != "$expect_null" ]]; then
            log_err "[self-test] $label: expected all_null=$expect_null, got $got"
            fail=1
        fi
        local got_fp="false"
        [[ "$got" -gt 0 ]] && got_fp="true"
        if [[ "$got_fp" != "$expect_fingerprint" ]]; then
            log_err "[self-test] $label: expected fingerprint=$expect_fingerprint, got $got_fp"
            fail=1
        fi
    }
    _check_classify "$fixture_null"  2 true  "all-null bucket"
    _check_classify "$fixture_true"  0 false "explicit-true bucket"
    _check_classify "$fixture_false" 0 false "explicit-false bucket"

    if [[ "$fail" -eq 0 ]]; then
        log_ok "[self-test] all 3 buckets pass (all-null, explicit-true, explicit-false)"
        return 0
    fi
    return 1
}

