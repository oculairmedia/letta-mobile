#!/bin/bash
# Comprehensive CLI for testing Letta SDK endpoints
# Mirrors all functionality available in the Android app

BASE_URL="${LETTA_URL:-http://192.168.50.90:8289}"
JQ_OPTS="-r"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err() { echo -e "${RED}[ERROR]${NC} $1"; }

usage() {
    cat << EOF
letta-cli - Test Letta SDK endpoints (mirrors Android app functionality)

USAGE:
    letta-cli <command> [options]

COMMANDS:
    # Counts (Dashboard)
    count agents|tools|blocks|conversations

    # Agents
    agents list [--limit N] [--tags TAG]
    agents get <agent_id>
    agents create <name> [--model MODEL]
    agents delete <agent_id>

    # Conversations
    conversations list [--limit N] [--agent_id ID]
    conversations get <conversation_id>
    conversations messages <conversation_id> [--limit N]

    # Messages
    messages list <agent_id> [--limit N] [--order asc|desc] [--after ID] [--before ID] [--conversation ID]
    messages check-new <agent_id> <after_id> [--conversation ID]
    messages send <conversation_id> <text>

    # Tools
    tools list [--limit N]
    tools get <tool_id>
    tools count

    # Blocks
    blocks list [--limit N] [--label LABEL]
    blocks get <block_id>
    blocks count

    # Runs (for monitoring)
    runs list [--agent_id ID] [--limit N]
    runs get <run_id>

    # Jobs
    jobs list [--limit N]
    jobs get <job_id>

    # MCP Servers
    mcp list
    mcp get <server_id>
    mcp tools <server_id>

    # Models & Providers
    models list
    providers list

    # Health/Debug
    health
    test-sync <agent_id> [--conversation ID]  # Full sync test
    classify-approvals <conversation_id> [--json]  # First-line UI-mislabel diagnostic (letta-mobile-3nqa)

ENVIRONMENT:
    LETTA_URL    Server URL (default: http://192.168.50.90:8289)
    LETTA_TOKEN  Auth token (optional)

EXAMPLES:
    letta-cli count agents
    letta-cli agents list --limit 10
    letta-cli messages list agent-xxx --limit 5 --order desc
    letta-cli test-sync agent-xxx --conversation conv-yyy
EOF
}

api_get() {
    local path="$1"
    curl -s -H "Authorization: Bearer ${LETTA_TOKEN:-}" "$BASE_URL$path"
}

api_post() {
    local path="$1"
    local data="$2"
    curl -s -X POST -H "Content-Type: application/json" -H "Authorization: Bearer ${LETTA_TOKEN:-}" -d "$data" "$BASE_URL$path"
}

api_delete() {
    local path="$1"
    curl -s -X DELETE -H "Authorization: Bearer ${LETTA_TOKEN:-}" "$BASE_URL$path"
}

# ============== COUNT ==============
cmd_count() {
    local resource="$1"
    case "$resource" in
        agents) api_get "/v1/agents/count" ;;
        tools) api_get "/v1/tools/count" ;;
        blocks) api_get "/v1/blocks/count" ;;
        conversations) api_get "/v1/conversations/?limit=10000" | jq 'length' ;;
        *) log_err "Unknown resource: $resource (try: agents, tools, blocks, conversations)"; return 1 ;;
    esac
}

# ============== AGENTS ==============
cmd_agents() {
    local subcmd="$1"; shift
    case "$subcmd" in
        list)
            local limit=50 tags=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --limit) limit="$2"; shift 2 ;;
                    --tags) tags="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            local url="/v1/agents?limit=$limit"
            [[ -n "$tags" ]] && url+="&tags=$tags"
            api_get "$url" | jq $JQ_OPTS '.[] | "\(.id) | \(.name) | \(.created_at[:10])"'
            ;;
        get)
            local agent_id="$1"
            api_get "/v1/agents/$agent_id" | jq .
            ;;
        create)
            local name="$1"; shift
            local model="letta/letta-free"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --model) model="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            api_post "/v1/agents" "{\"name\": \"$name\", \"model\": \"$model\"}" | jq .
            ;;
        delete)
            local agent_id="$1"
            api_delete "/v1/agents/$agent_id"
            log_ok "Deleted agent $agent_id"
            ;;
        *) log_err "Unknown agents command: $subcmd" ;;
    esac
}

# ============== CONVERSATIONS ==============
cmd_conversations() {
    local subcmd="$1"; shift
    case "$subcmd" in
        list)
            local limit=20 agent_id=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --limit) limit="$2"; shift 2 ;;
                    --agent_id) agent_id="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            local url="/v1/conversations/?limit=$limit"
            [[ -n "$agent_id" ]] && url+="&agent_id=$agent_id"
            api_get "$url" | jq $JQ_OPTS '.[] | "\(.id) | \(.agent_id[:30])... | \(.created_at[:19])"'
            ;;
        get)
            local conv_id="$1"
            api_get "/v1/conversations/$conv_id" | jq .
            ;;
        messages)
            local conv_id="$1"; shift
            local limit=50
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --limit) limit="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            api_get "/v1/conversations/$conv_id/messages?limit=$limit" | jq $JQ_OPTS '.[] | "\(.date[:19] // "?") | \(.message_type[:20]) | \((.content // .reasoning // "")[:50])"'
            ;;
        *) log_err "Unknown conversations command: $subcmd" ;;
    esac
}

# ============== MESSAGES ==============
cmd_messages() {
    local subcmd="$1"; shift
    case "$subcmd" in
        list)
            local agent_id="$1"; shift
            local limit=10 order="desc" after="" before="" conversation=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --limit) limit="$2"; shift 2 ;;
                    --order) order="$2"; shift 2 ;;
                    --after) after="$2"; shift 2 ;;
                    --before) before="$2"; shift 2 ;;
                    --conversation) conversation="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            local url="/v1/agents/$agent_id/messages?limit=$limit&order=$order"
            [[ -n "$after" ]] && url+="&after=$after"
            [[ -n "$before" ]] && url+="&before=$before"
            [[ -n "$conversation" ]] && url+="&conversation_id=$conversation"
            
            log_info "GET $url"
            api_get "$url" | jq $JQ_OPTS '
                "Found \(length) messages\n",
                (.[] | "\(.date[:19] // "?") | \(.message_type[:20] | . + " " * (20 - length)) | \((.content // .reasoning // (.tool_calls[0].name // .message_type))[:60] | gsub("\n"; " "))\n  ID: \(.id)")
            '
            ;;
        check-new)
            local agent_id="$1"
            local after_id="$2"
            shift 2
            local conversation=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation) conversation="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            local url="/v1/agents/$agent_id/messages?limit=50&order=asc&after=$after_id"
            [[ -n "$conversation" ]] && url+="&conversation_id=$conversation"
            
            log_info "Checking for NEW messages after: $after_id"
            api_get "$url" | jq $JQ_OPTS '
                "Found \(length) NEW messages\n",
                (.[] | "\(.date[:19] // "?") | \(.message_type[:20]) | \((.content // .reasoning // "")[:50])")
            '
            ;;
        send)
            local conv_id="$1"
            local text="$2"
            log_info "Sending message to conversation $conv_id"
            api_post "/v1/conversations/$conv_id/messages" "{\"messages\": [{\"role\": \"user\", \"content\": \"$text\"}]}" | jq .
            ;;
        *) log_err "Unknown messages command: $subcmd" ;;
    esac
}

