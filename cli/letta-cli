    local subcmd="$1"; shift
    case "$subcmd" in
        list)
            local limit=50
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --limit) limit="$2"; shift 2 ;;
                    *) shift ;;
                esac
            done
            api_get "/v1/tools?limit=$limit" | jq $JQ_OPTS '.[] | "\(.id) | \(.name) | \(.source_type // "?")"'
            ;;
        get)
            local tool_id="$1"
            api_get "/v1/tools/$tool_id" | jq .
            ;;
        count)
            api_get "/v1/tools/count"
            ;;
        *) log_err "Unknown tools command: $subcmd" ;;
