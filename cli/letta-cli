            [[ -n "$label" ]] && url+="&label=$label"
            api_get "$url" | jq $JQ_OPTS '.[] | "\(.id) | \(.label // "?") | \(.value[:40] | gsub("\n"; " "))..."'
            ;;
        get)
            local block_id="$1"
            api_get "/v1/blocks/$block_id" | jq .
            ;;
        count)
            api_get "/v1/blocks/count"
